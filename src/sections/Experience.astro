---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface ExperienceItem {
    duration: string;
    role: string;
    company: string;
    description: string[];
    isCurrent: boolean;
}

const experienceData = await import(`../data/${lang}/experience.json`);
const experience = experienceData.experience as ExperienceItem[];
---

<main>
    <section
        id="experience"
        class="scroll-mt-20"
    >
        <div class="mx-auto my-24 w-full max-w-5xl px-4 sm:my-40">
            <h2
                class="mb-7 text-3xl font-semibold text-black/80 dark:text-white"
            >
                {t('experience.years')}
            </h2>
            <div class="flex flex-col gap-4">
                {
                    experience.map((exp, index) => (
                        <div
                            data-experience-card
                            class={`flex flex-col justify-center rounded-lg border ${exp.isCurrent ? 'border-blue-400 dark:border-blue-500' : 'border-gray-100 dark:border-gray-800'} animate-fade-in bg-[#fffdff] p-6 dark:bg-[#13151a]`}
                            style={`animation-delay: ${index * 200}ms;`}
                        >
                            <time class="mb-1 block text-sm text-black/70 md:hidden dark:text-white/70">
                                {exp.duration}
                            </time>
                            <div class="mb-1 flex items-baseline justify-between">
                                <h3 class="text-lg font-bold text-blue-400 dark:text-blue-500">
                                    {exp.role}
                                </h3>
                                <time class="hidden text-sm text-black/70 md:block dark:text-white/70">
                                    {exp.duration}
                                </time>
                            </div>
                            <p class="mb-1 text-lg font-semibold text-black/80 dark:text-white/90">
                                {exp.company}
                            </p>
                            <ul class="list-disc space-y-1 pl-5 text-sm leading-relaxed text-black/90 sm:text-base dark:text-white/90">
                                {
                                    exp.description.slice(0, 3).map((description) => (
                                        <li>
                                            {description}
                                        </li>
                                    ))
                                }
                            </ul>
                            {
                                exp.description.length > 3 && (
                                    <>
                                        <div
                                            data-description-panel
                                            class="grid grid-rows-[0fr] opacity-0 transition-[grid-template-rows,opacity] duration-300 ease-in-out"
                                        >
                                            <div class="overflow-hidden">
                                                <ul class="list-disc space-y-1 pt-1 pl-5 text-sm leading-relaxed text-black/90 sm:text-base dark:text-white/90">
                                                    {exp.description.slice(3).map((description) => (
                                                        <li>{description}</li>
                                                    ))}
                                                </ul>
                                            </div>
                                        </div>
                                        <div class="mt-3 text-center">
                                            <button
                                                type="button"
                                                data-description-toggle
                                                aria-expanded="false"
                                                class="cursor-pointer text-sm font-semibold text-blue-500 transition-colors hover:text-blue-600 dark:text-blue-400 dark:hover:text-blue-300"
                                            >
                                                <span data-show-more>{t('experience.showMore')}</span>
                                                <span data-show-less hidden>{t('experience.showLess')}</span>
                                            </button>
                                        </div>
                                    </>
                                )
                            }
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</main>

<script>
    document.querySelectorAll<HTMLButtonElement>('[data-description-toggle]').forEach((button) => {
        button.addEventListener('click', () => {
            const isExpanded = button.getAttribute('aria-expanded') === 'true';
            const experienceCard = button.closest('[data-experience-card]');

            if (!experienceCard) return;

            const panel = experienceCard.querySelector<HTMLElement>('[data-description-panel]');

            if (!panel) return;

            if (!isExpanded) {
                document.querySelectorAll<HTMLElement>('[data-experience-card]').forEach((card) => {
                    if (card === experienceCard) return;

                    const otherPanel = card.querySelector<HTMLElement>('[data-description-panel]');
                    const otherButton = card.querySelector<HTMLButtonElement>('[data-description-toggle]');

                    if (!otherPanel || !otherButton) return;

                    otherPanel.classList.remove('grid-rows-[1fr]', 'opacity-100');
                    otherPanel.classList.add('grid-rows-[0fr]', 'opacity-0');
                    otherButton.setAttribute('aria-expanded', 'false');
                    otherButton.querySelector<HTMLElement>('[data-show-more]')!.hidden = false;
                    otherButton.querySelector<HTMLElement>('[data-show-less]')!.hidden = true;
                });
            }

            button.setAttribute('aria-expanded', String(!isExpanded));
            panel.classList.toggle('grid-rows-[1fr]', !isExpanded);
            panel.classList.toggle('grid-rows-[0fr]', isExpanded);
            panel.classList.toggle('opacity-100', !isExpanded);
            panel.classList.toggle('opacity-0', isExpanded);
            button.querySelector<HTMLElement>('[data-show-more]')!.hidden = !isExpanded;
            button.querySelector<HTMLElement>('[data-show-less]')!.hidden = isExpanded;
        });
    });
</script>
